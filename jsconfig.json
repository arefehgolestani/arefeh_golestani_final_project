{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/public/*": ["public/*"],
      "@/app/*": ["src/app/*"],
      "@/utils/*": ["src/utils/*"],
      "@/layout/*": ["src/components/layout/*"],
      "@/modules/*": ["src/components/modules/*"],
      "@/templates/*": ["src/components/templates/*"],
      "@/context/*": ["src/context/*"],
      "@/lib/*": ["./lib/*"],
      "@/services/*": ["src/services/*"]
    }
  }
}
